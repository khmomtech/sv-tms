### Example environment file for /etc/default/tms-backend
# Copy to /etc/default/tms-backend on the VPS and set secure values.

# Spring datasource
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/tmsdb
SPRING_DATASOURCE_USERNAME=tms_user
SPRING_DATASOURCE_PASSWORD=change_me

# Additional environment
JAVA_OPTS='-Xms256m -Xmx1g -Dspring.profiles.active=prod'
SERVER_PORT=8080
