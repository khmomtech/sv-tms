[Unit]
Description=TMS Backend service
After=network.target

[Service]
Type=simple
User=www-data
# Set environment file if you want to supply DB and other secrets
EnvironmentFile=/etc/default/tms-backend
ExecStart=/usr/bin/java $JAVA_OPTS -jar /opt/tms-backend/app.jar
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
