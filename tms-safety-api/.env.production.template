# SV-TMS Backend Environment Variables
# Copy this file to .env and fill in production values
# NEVER commit .env to version control

# =========================================
# CRITICAL: JWT Secrets (Generate secure random values)
# =========================================
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_TO_SECURE_RANDOM_64_BYTE_VALUE
JWT_REFRESH_SECRET=CHANGE_ME_TO_DIFFERENT_SECURE_RANDOM_64_BYTE_VALUE
JWT_ACCESS_TTL_MS=900000
JWT_REFRESH_TTL_MS=2592000000

# =========================================
# CRITICAL: API Key
# =========================================
# Generate with: openssl rand -hex 32
APP_API_KEY=CHANGE_ME_TO_SECURE_RANDOM_HEX_VALUE

# =========================================
# Database Configuration
# =========================================
DB_URL=jdbc:mysql://localhost:3307/svlogistics_tms_db?useUnicode=true&characterEncoding=UTF-8&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=driver
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# =========================================
# Redis Configuration
# =========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================================
# Firebase Configuration
# =========================================
FIREBASE_CONFIG_PATH=/path/to/firebase-adminsdk.json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-adminsdk.json

# =========================================
# Google Maps API
# =========================================
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# =========================================
# CORS Configuration
# =========================================
CORS_ALLOWED_ORIGINS=https://svtms.svtrucking.biz

# =========================================
# Profile (local, dev, prod)
# =========================================
SPRING_PROFILES_ACTIVE=prod

# =========================================
# Production Generation Commands
# =========================================
# Run these commands to generate secure secrets:
#
# JWT_ACCESS_SECRET=$(openssl rand -base64 64 | tr -d '\n')
# JWT_REFRESH_SECRET=$(openssl rand -base64 64 | tr -d '\n')
# APP_API_KEY=$(openssl rand -hex 32)
# DB_PASSWORD=$(openssl rand -base64 32 | tr -d '/+=' | cut -c1-24)
