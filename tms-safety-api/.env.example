# Example environment variables for local development
# Copy this file to .env and fill values (do NOT commit secrets)

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/svlogistics
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=changeme

JWT_SECRET=replace-with-secure-secret
FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json
# driver-app (Spring Boot) environment example
# Copy this to `driver-app/.env` and edit values for local development.

# Datasource
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/driverapp?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=driver
SPRING_DATASOURCE_PASSWORD=driverpass

# Spring profile (local/dev/prod)
SPRING_PROFILES_ACTIVE=local

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRATION_MS=3600000

# Firebase (local: path to service account JSON mounted into container)
FIREBASE_CREDENTIALS=/run/secrets/firebase_service_account.json

# Optional: storage/upload path
UPLOADS_DIR=/app/uploads
