{
  "info": {
    "name": "SV-TMS Backend - Customer API (sample)",
    "_postman_id": "b02a3a34-44e2-4e7f-a7b9-9bc0b55288a1",
    "description": "Sample Postman collection: login (JWT) + list customer orders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login - Obtain JWT",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"customer@example.com\",\n  \"password\": \"password\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "const token = body?.token || body?.accessToken || body?.data?.token;",
              "if (token) pm.environment.set('jwt', token);",
              "// try decode JWT payload for customerId if present",
              "if (token && token.split('.').length===3) {",
              "  try {",
              "    const payload = JSON.parse(atob(token.split('.')[1].replace(/-/g,'+').replace(/_/g,'/')));",
              "    if (payload.customerId) pm.environment.set('customerId', String(payload.customerId));",
              "    if (payload.sub && !pm.environment.get('customerId')) pm.environment.set('customerId', payload.sub);",
              "  } catch(e) {}",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "List Orders - Customer",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/customer/{{customerId}}/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "customer",
            "{{customerId}}",
            "orders"
          ]
        }
      }
    }
  ]
}
