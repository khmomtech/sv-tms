{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "module": "ES2022",
    "target": "ES2022",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": false,
    "strict": false,
    "noImplicitAny": false,
    "types": ["jasmine", "node"]
  },
  "include": [
    "src/test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
