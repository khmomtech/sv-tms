# TMS Frontend - Environment Variables Template
# Copy this file to .env.production or .env.local and fill in your values
# NEVER commit .env files with real secrets to version control

# ==============================================================================
# Environment
# ==============================================================================
ENVIRONMENT=production
APP_VERSION=1.0.0

# ==============================================================================
# API Configuration
# ==============================================================================
API_BASE_URL=https://api.example.com
WS_SOCKET_URL=wss://api.example.com/ws
SOCKJS_URL=https://api.example.com/ws-sockjs
USE_SOCKJS=true

# ==============================================================================
# Google Maps (REQUIRED)
# ==============================================================================
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Restrict by HTTP referrer (e.g., yourdomain.com/*)
GOOGLE_MAPS_API_KEY=AIzaSy...your-key-here

# ==============================================================================
# Firebase Configuration (REQUIRED for authentication)
# ==============================================================================
# Get these values from Firebase Console > Project Settings > General
FIREBASE_API_KEY=AIzaSy...your-firebase-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abc123def456
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ==============================================================================
# Error Monitoring (RECOMMENDED)
# ==============================================================================
# Get your DSN from: https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=https://abc123def456@o123456.ingest.sentry.io/123456

# ==============================================================================
# Feature Flags
# ==============================================================================
USE_SERVER_PAGING_PARTNERS=false
USE_VENDOR_API_PATHS=true
VENDOR_DISPLAY_TERM=Vendor

# ==============================================================================
# Docker Configuration
# ==============================================================================
DOCKER_USERNAME=your-dockerhub-username
DOCKER_IMAGE_NAME=tms-frontend
DOCKER_IMAGE_TAG=latest

# ==============================================================================
# CI/CD Secrets (GitHub Actions)
# ==============================================================================
# These should be set in GitHub repository secrets, not in .env files
# DOCKER_USERNAME - Docker Hub username
# DOCKER_PASSWORD - Docker Hub password/token
# LHCI_GITHUB_APP_TOKEN - Lighthouse CI GitHub App token (optional)
# CODECOV_TOKEN - Codecov upload token (optional)

