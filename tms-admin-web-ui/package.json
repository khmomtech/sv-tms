{
  "name": "tms-admin-web-ui",
  "version": "0.0.0",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.cjs",
    "build": "ng build",
    "serve": "ng serve --port 4200",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox --code-coverage",
    "test:debug": "ng test --watch --browsers=ChromeHeadlessNoSandbox",
    "test:coverage": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox --code-coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:smoke": "playwright test e2e/smoke-routes.spec.ts --project=chromium --reporter=list",
    "test:e2e:smoke:ui": "playwright test e2e/smoke-routes.spec.ts --project=chromium --ui",
    "test:unit": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox",
    "test:unit:one": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox --include src/app/services/partner.service.spec.ts",
    "test:integration": "playwright test e2e/integration/",
    "test:integration:api": "playwright test e2e/integration/api-contracts.spec.ts",
    "test:integration:ws": "playwright test e2e/integration/websocket-integration.spec.ts",
    "test:flows": "playwright test e2e/flows/",
    "test:flows:driver": "playwright test e2e/flows/driver-crud-flow.spec.ts",
    "test:flows:vehicle": "playwright test e2e/flows/vehicle-crud-flow.spec.ts",
    "test:performance": "playwright test e2e/performance/",
    "test:visual": "playwright test e2e/visual/",
    "test:visual:update": "playwright test e2e/visual/ --update-snapshots",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:flows && npm run test:performance",
    "test:quick": "npm run test:unit && npm run test:integration:api",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss}\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test:headless": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox --code-coverage",
    "audit": "npm audit",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "lighthouse:upload": "lhci upload",
    "prepare": "husky install",
    "refactor:imports": "node scripts/fix-imports.js",
    "refactor:verify": "npm run lint:fix && npm run build && npm test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.15",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.15",
    "@angular/compiler": "^19.2.15",
    "@angular/core": "^19.2.15",
    "@angular/forms": "^19.2.15",
    "@angular/google-maps": "^19.2.19",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.15",
    "@angular/platform-browser-dynamic": "^19.2.15",
    "@angular/router": "^19.2.15",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@googlemaps/extended-component-library": "^0.6.14",
    "@googlemaps/markerclusterer": "^2.5.3",
    "@ng-select/ng-select": "^14.9.0",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "@popperjs/core": "^2.11.8",
    "@sentry/angular": "^10.28.0",
    "@sentry/tracing": "^7.120.4",
    "@stomp/rx-stomp": "^2.3.0",
    "@stomp/stompjs": "^7.1.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "agora-rtc-sdk-ng": "^4.24.3",
    "bootstrap": "^5.3.6",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.4.9",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "kalmanjs": "^1.1.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "mapbox-gl": "^3.19.0",
    "ng2-charts": "^8.0.0",
    "ngx-toastr": "^19.0.0",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.2",
    "sockjs-client": "^1.6.1",
    "sweetalert2": "^11.22.3",
    "tslib": "^2.6.2",
    "web-vitals": "^5.1.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.19",
    "@angular/cli": "^19.2.19",
    "@angular/compiler-cli": "^19.2.15",
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@lhci/cli": "^0.15.1",
    "@ngtools/webpack": "^19.2.19",
    "@playwright/test": "^1.57.0",
    "@types/date-fns": "^2.5.3",
    "@types/file-saver": "^2.0.7",
    "@types/google.maps": "^3.58.1",
    "@types/html2canvas": "^0.5.35",
    "@types/jasmine": "~5.1.0",
    "@types/jspdf": "^1.3.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.9",
    "@types/qrcode": "^1.5.5",
    "@types/sockjs-client": "^1.5.4",
    "@typescript-eslint/eslint-plugin": "^8.12.1",
    "@typescript-eslint/parser": "^8.12.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.13.0",
    "eslint-plugin-import": "^2.29.0",
    "husky": "^9.1.7",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-nesting": "^14.0.0",
    "pre-commit": "^1.2.2",
    "prettier": "^3.6.2",
    "puppeteer": "^24.15.0",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.8.2",
    "webpack": "^5.104.1"
  }
}
