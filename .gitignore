.dart_tool/
.packages
pubspec.lock
.flutter-plugins
.flutter-plugins-dependencies
Pods/

# Java specific
*.class
*.jar
!**/src/main/**/target/*.jar
!**/src/test/**/target/*.jar

# Development artifacts
PasswordHashTest.java
test_*.py
gen_*.py
*_backup.xlsx

# Session and debug files
session-*.html
debug-*.log
backend-*.log

