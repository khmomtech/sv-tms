# =============================================================================
# SV-TMS Production Environment — copy to infra/.env and fill every value
# NEVER commit the real .env file to git.
#
# Generate secrets with:
#   JWT secrets:  openssl rand -hex 64
#   API keys:     openssl rand -hex 32
#   Kafka ID:     cat /proc/sys/kernel/random/uuid | tr -d '-' | cut -c1-22
# =============================================================================

# ── Domain / TLS ──────────────────────────────────────────────────────────────
DOMAIN=svtms.svtrucking.biz
EMAIL=ops@svtrucking.biz

# ── Persistent storage root on the host ──────────────────────────────────────
DATA_ROOT=/srv/svtms

# ── Docker image registry ─────────────────────────────────────────────────────
# Use "local" to run images built directly on the VPS (via build_images_on_vps.sh)
# Use "ghcr.io/YOUR_GITHUB_ORG" when using GitHub Actions CI/CD to push images
IMAGE_REGISTRY=local
IMAGE_TAG=latest
BACKUP_RETENTION_DAYS=14

# ── Core MySQL ────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password
MYSQL_DATABASE=svlogistics_tms_db
MYSQL_USER=svtms_app
MYSQL_PASSWORD=CHANGE_ME_strong_app_password

# ── Telematics PostgreSQL ─────────────────────────────────────────────────────
TELEMATICS_POSTGRES_DB=svlogistics_telematics
TELEMATICS_POSTGRES_USER=telematics_app
TELEMATICS_POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# ── MongoDB (location history) ────────────────────────────────────────────────
MONGO_DATABASE=svlogistics_tms_db

# ── Kafka KRaft cluster ID ────────────────────────────────────────────────────
# Generate: cat /proc/sys/kernel/random/uuid | tr -d '-' | cut -c1-22
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# ── JWT + internal API keys ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
TELEMATICS_INTERNAL_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── CORS / WebSocket allowed origins ─────────────────────────────────────────
APP_CORS_ALLOWED_ORIGINS=https://svtms.svtrucking.biz
APP_WEBSOCKET_ALLOWED_ORIGINS=https://svtms.svtrucking.biz

# ── Google Maps API key (for driver app builds) ───────────────────────────────
MAPS_API_KEY=CHANGE_ME_your_google_maps_api_key

# ── Firebase credentials (place .json file on VPS before deploying) ───────────
FIREBASE_CREDENTIALS_PATH=/opt/sv-tms/secrets/firebase-service-account.json

# ── Monitoring / Grafana ──────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_grafana_password

# ── SMTP (optional — for email alerts) ───────────────────────────────────────
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=alerts@svtrucking.biz
# SPRING_MAIL_PASSWORD=YOUR_APP_PASSWORD
