# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  # Note: Do NOT inhibit warnings globally. Upgrading offending plugins is preferred
  # to ensure App Store compliance and to surface deprecation fixes.

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  # RunnerTests target removed from Podfile to avoid CocoaPods Swift-version
  # uniqueness conflicts during CI/local flavor builds. Tests do not require
  # CocoaPods-managed frameworks to build the app archive.
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    # Ensure a single Swift version across all pod targets to avoid CocoaPods
    # "up to 1 unique SWIFT_VERSION per target" errors when project has
    # mixed/empty values.
    target.build_configurations.each do |config|
      config.build_settings['SWIFT_VERSION'] = '5.0'
    end
  end

  # Replace AppTrackingTransparency permission strategy sources with
  # lightweight stubs if present. This avoids linking to the
  # AppTrackingTransparency framework while keeping headers available so
  # compilation does not fail due to missing imports.
  pub_paths = [
    File.join(Dir.home, '.pub-cache', 'hosted', 'pub.dev', 'permission_handler_apple-*', 'ios', 'Classes', 'strategies'),
    File.join(installer.sandbox.root.to_s, 'permission_handler_apple', 'ios', 'Classes', 'strategies')
  ]

  pub_paths.each do |dir_pattern|
    Dir[dir_pattern].each do |dir|
      h = File.join(dir, 'AppTrackingTransparencyPermissionStrategy.h')
      m = File.join(dir, 'AppTrackingTransparencyPermissionStrategy.m')
      if File.exist?(h) || File.exist?(m)
        puts "Creating stub for AppTrackingTransparencyPermissionStrategy in #{dir}"
        begin
          File.write(h, <<-HEADER)
#import <Foundation/Foundation.h>

@interface AppTrackingTransparencyPermissionStrategy : NSObject

- (void)requestPermission;

@end
          HEADER
        rescue => e
          puts "Failed to write stub header: #{e}"
        end

        begin
          File.write(m, <<-IMPL)
#import "AppTrackingTransparencyPermissionStrategy.h"

@implementation AppTrackingTransparencyPermissionStrategy

- (void)requestPermission {
  // Stub: intentionally left blank to avoid using ATTrackingManager
}

@end
          IMPL
        rescue => e
          puts "Failed to write stub impl: #{e}"
        end
      end
    end
  end
end
